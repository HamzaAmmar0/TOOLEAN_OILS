{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury hair oil product in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "categories": { "type": "array", "items": { "type": "string" } },
        "filters": {
          "type": "object",
          "properties": {
            "hairType": { "type": "array", "items": { "type": "string" } },
            "concern": { "type": "array", "items": { "type": "string" } },
            "ingredient": { "type": "array", "items": { "type": "string" } }
          }
        },
        "stock": { "type": "number" },
        "discountRate": { "type": "number", "description": "Percentage discount (0-100)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "images", "categories", "filters", "stock"]
    },
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "admin"] },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "priceAtPurchase": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "discountApplied": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "fulfilled", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Analytics": {
      "title": "Analytics Event",
      "description": "System events for visits and sales.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["visit", "sale"] },
        "data": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "timestamp"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Catalog of products."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles determining basic roles (e.g., admin)."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    },
    "analytics/{eventId}": {
      "schema": { "$ref": "#/entities/Analytics" },
      "description": "Time-series analytics for revenue and engagement."
    }
  }
}
